# ==================== 数据库 ====================
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
POSTGRES_DB=rag_db
DATABASE_URL=postgresql://rag_user:rag_password@postgres:5432/rag_db

# ==================== JWT ====================
SECRET_KEY=change-me-to-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_SECRET_KEY=change-me-to-another-random-secret
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# ==================== DeepSeek LLM ====================
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ==================== Qwen-VL / vLLM（可选） ====================
# VISION_MODEL 留空表示关闭；vLLM --served-model-name 应与这里一致
VISION_MODEL=
VISION_BASE_URL=http://127.0.0.1:8001/v1
VISION_API_KEY=EMPTY
VISION_TIMEOUT_SECONDS=20
VISION_MAX_RETRIES=0
VISION_MAX_TOKENS=400
VISION_MAX_IMAGE_EDGE=1600
VISION_CACHE_CAPTIONS=true
VISION_MAX_CAPTIONS_PER_DOCUMENT=8
VISION_SKIP_CAPTION_OCR_CHARS=120
VISION_TEXT_DEDUP_THRESHOLD=0.72
RAG_OCR_CONCURRENCY=3
RAG_VISION_CONCURRENCY=2
VISION_GLOBAL_CONCURRENCY=2
VISION_GLOBAL_ACQUIRE_TIMEOUT_SECONDS=30
VISION_GLOBAL_SLOT_TTL_SECONDS=45
RAG_DOCUMENT_TIMEOUT_SECONDS=1800
RAG_OCR_TIMEOUT_SECONDS=15
RAG_NEARBY_TEXT_MAX_VERTICAL_RATIO=0.18
RAG_NEARBY_TEXT_MIN_HORIZONTAL_OVERLAP=0.20
RAG_NEARBY_TEXT_MAX_BLOCKS=2
RAG_NEARBY_TEXT_MAX_CHARS=800

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
REDIS_PASSWORD=
CELERY_DOCUMENT_QUEUE=document_index
CELERY_WORKER_CONCURRENCY=2
CELERY_RESULT_EXPIRES_SECONDS=3600
CELERY_VISIBILITY_TIMEOUT_SECONDS=3600
SHORT_TERM_MEMORY_MESSAGES=12
SHORT_TERM_MEMORY_TTL_SECONDS=86400
SHORT_TERM_MESSAGE_MAX_CHARS=4000

# ==================== Qdrant ====================
# 本机 uvicorn 连接 Docker Qdrant 用 127.0.0.1；Docker 容器内部会使用 http://qdrant:6333
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false
QDRANT_COLLECTION_NAME=chatai_chunks
QDRANT_DIM=1024

# ==================== 文件存储 ====================
# UPLOAD_DIR 留空使用默认 ./uploads
UPLOAD_DIR=

# ==================== 模型 ====================
# 本地模型存放目录，两个模型共约 3.5GB
# 下载: bash scripts/download-models.sh /path/to/models
# Windows Docker Desktop 示例: MODEL_ROOT=E:/models
MODEL_ROOT=~/models

# ==================== 服务配置 ====================
HOST=127.0.0.1
PORT=8001
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=true


DB_ECHO=false
RUN_MIGRATIONS_ON_STARTUP=false
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CREATE_SEED_ADMIN=false
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=
MAX_DOCUMENT_SIZE_MB=50
DOCUMENT_UPLOAD_CHUNK_BYTES=1048576
DOC_INDEX_MAX_RETRIES=2
DOC_INDEX_LOCK_TTL_SECONDS=300
DOC_INDEX_LOCK_HEARTBEAT_SECONDS=60
RAG_ANSWER_TEMPERATURE=0.1
RAG_ANSWER_MAX_TOKENS=2000
RAG_ANSWER_TIMEOUT_SECONDS=60
RAG_ANSWER_MAX_RETRIES=1
RAG_MAX_CONTEXT_CHARS=8000
RAG_QUERY_REWRITE_ENABLED=true
RAG_QUERY_REWRITE_MODEL=deepseek-v4-flash
RAG_QUERY_REWRITE_TEMPERATURE=0.0
RAG_QUERY_REWRITE_MAX_CHARS=300
RAG_HISTORY_MESSAGES=12
RAG_COMPACTION_THRESHOLD=24
RAG_SUMMARY_MAX_CHARS=5000
RAG_MEMORY_MAX_TOKENS=16000
RAG_MEMORY_SUMMARY_MAX_TOKENS=2000
RAG_MEMORY_RECENT_MAX_TOKENS=3500
RAG_MEMORY_TASK_STATE_MAX_TOKENS=500
RAG_TOKENIZER_MODEL=
RAG_TOKENIZER_LOCAL_ONLY=true
# ==================== RAGAS / 人工评估 ====================
# 生成 RAGAS 实际答案时使用；可被命令行参数覆盖。
RAG_EVAL_BASE_URL=http://127.0.0.1:8001
RAG_EVAL_TOKEN=
RAG_EVAL_USERNAME=
RAG_EVAL_PASSWORD=
# 兼容通用 RAG 客户端脚本；可与上面的 RAG_EVAL_* 保持一致。
RAG_USERNAME=
RAG_PASSWORD=
RAG_EVAL_TOP_K=3
RAG_EVAL_BM25_WEIGHT=0.4
RAG_RERANK_CANDIDATES=16
RAG_EVAL_CONTEXT_MODE=chunk
RAG_EVAL_REWRITE_QUERY=false

# RAGAS 评估 LLM。留空 RAGAS_LLM_API_KEY 时会复用 DEEPSEEK_API_KEY。
RAGAS_LLM_API_KEY=
RAGAS_LLM_BASE_URL=https://api.deepseek.com
RAGAS_LLM_MODEL=deepseek-chat
RAGAS_TIMEOUT_SECONDS=120
RAGAS_MAX_RETRIES=2

# answer_relevancy 需要 embedding。local 使用本地 BGE，无需额外 API key；openai 使用下面的 API key。
RAGAS_EMBEDDING_PROVIDER=local
RAGAS_LOCAL_EMBEDDING_MODEL=E:/models/bge-large-zh-v1.5
RAGAS_LOCAL_EMBEDDING_BATCH_SIZE=16
RAGAS_EMBEDDING_API_KEY=
RAGAS_EMBEDDING_BASE_URL=https://api.openai.com/v1
RAGAS_EMBEDDING_MODEL=text-embedding-3-small
RAG_EVAL_KB_ID=1
HUGGING_FACE_HUB_TOKEN=
RAG_MEMORY_EXTRACTION_INTERVAL_MESSAGES=10
RAG_MEMORY_EXTRACTION_MIN_CHARS=30
RAG_MEMORY_EXTRACTION_MESSAGE_HEAD_CHARS=300
RAG_MEMORY_EXTRACTION_MESSAGE_TAIL_CHARS=1000
