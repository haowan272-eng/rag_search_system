# Copy to .env on the deployment host and replace all secret values.

POSTGRES_USER=rag_user
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=rag_db
DATABASE_URL=postgresql://rag_user:change-me-postgres-password@postgres:5432/rag_db

REDIS_PASSWORD=change-me-redis-password

SECRET_KEY=change-me-to-a-long-random-secret
REFRESH_SECRET_KEY=change-me-to-another-long-random-secret

DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

CORS_ORIGINS=http://localhost
LOG_LEVEL=INFO
LOG_JSON=true

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false

# Leave empty to disable local Qwen-VL/vLLM vision captioning.
VISION_MODEL=
VISION_BASE_URL=http://host.docker.internal:8001/v1
VISION_API_KEY=EMPTY
